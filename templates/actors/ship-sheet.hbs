<form class="roguetrader ship-sheet" autocomplete="off">
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="page-one">Voidship</a>
    <a class="item" data-tab="page-two">Hull & Records</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="page-one">
      <div class="ship-sheet-frame">
        <header class="ship-sheet-header">
          <div class="ship-sheet-title-block">
            <input class="ship-sheet-name" name="name" type="text" value="{{actor.name}}" placeholder="Voidship Name" />
            <div class="ship-sheet-meta">
              <div class="ship-stat-line">
                <label>Class</label>
                <input name="system.class" type="text" value="{{system.class}}" />
              </div>
              <div class="ship-stat-line">
                <label>Hull</label>
                <input name="system.hull" type="text" value="{{system.hull}}" />
              </div>
              <div class="ship-stat-line ship-stat-line-compact">
                <label>Ship Points</label>
                <input name="system.shipPoints.value" type="number" value="{{system.shipPoints.value}}" step="1" />
              </div>
              <div class="ship-stat-line ship-stat-line-compact">
                <label>Ship Control</label>
                <select name="system.controlMode">
                  {{#each ship.controlModeOptions as |option|}}
                    <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                  {{/each}}
                </select>
              </div>
            </div>
            <div class="ship-title-actions">
              <button type="button" class="ship-construct-button">Construct Voidship</button>
            </div>
          </div>
          <div class="ship-sheet-art">
            <img src="{{ship.art}}" data-edit="img" title="{{actor.name}}" />
          </div>
        </header>

        {{#if ship.isNpcControlled}}
          <section class="ship-card ship-roster-card">
            <h2>NPC Crew</h2>
            <div class="ship-npc-crew-panel">
              <div class="ship-npc-crew-field">
                <label>Crew Rating</label>
                <select name="system.npcCrewRating">
                  {{#each ship.npcCrewRatingOptions as |option|}}
                    <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                  {{/each}}
                </select>
              </div>
              <div class="ship-npc-crew-summary">
                <div class="ship-npc-crew-target">{{ship.npcCrewRating}}</div>
                <div class="ship-npc-crew-text">Base target number for voidship tests.</div>
              </div>
            </div>
          </section>
        {{else}}
          <section class="ship-card ship-roster-card">
            <h2>Voidship Roster</h2>
            <div class="ship-roster-grid">
              {{#each ship.roster as |role|}}
                <div
                  class="ship-roster-slot {{#if role.isAssigned}}is-draggable{{/if}}"
                  data-ship-roster-role="{{role.key}}"
                  data-actor-uuid="{{role.actorUuid}}"
                  {{#if role.isAssigned}}draggable="true"{{/if}}>
                  <img class="ship-roster-portrait" src="{{role.portrait}}" alt="{{role.assignedName}}" />
                  <div class="ship-roster-content">
                    <div class="ship-roster-header">
                      <div class="ship-roster-role">{{role.label}}</div>
                      {{#if role.isAssigned}}
                        <button type="button" class="ship-roster-clear" data-ship-roster-role="{{role.key}}" aria-label="Clear {{role.label}}">
                          <i class="fas fa-times"></i>
                        </button>
                      {{/if}}
                    </div>
                    <div class="ship-roster-assignment">{{role.assignedName}}</div>
                    {{#unless role.isAssigned}}
                      <div class="ship-roster-hint">Drag a character onto this slot.</div>
                    {{/unless}}
                    <div class="ship-roster-stat">
                      <label>{{role.primaryLabel}}</label>
                      <strong>{{role.primaryValueLabel}}</strong>
                    </div>
                  </div>
                </div>
              {{/each}}
            </div>
          </section>
        {{/if}}

        <section class="ship-card ship-actions-card">
          <div class="ship-section-header">
            <h2>Voidship Actions</h2>
          </div>
          <div class="ship-actions-grid">
            {{#each ship.actions as |action|}}
              <button
                type="button"
                class="ship-action-button {{#if action.isAssigned}}is-assigned{{/if}}"
                data-action-key="{{action.key}}"
                data-tooltip="{{action.tooltip}}">
                <span class="ship-action-label">{{action.label}}</span>
                <span class="ship-action-meta">{{action.mode}} / {{action.subtype}}</span>
                {{#if action.isAssigned}}
                  <span class="ship-action-assignee" title="{{action.assignedName}}">{{action.initials}}</span>
                {{/if}}
              </button>
            {{/each}}
          </div>
        </section>

        <section class="ship-sheet-main">
          <section class="ship-card ship-profile-card ship-profile-resources-card">
            <h2>Voidship Profile &amp; Resources</h2>
            {{#if ship.isCrippled}}
              <p class="ship-condition-note">Crippled: Speed halved, Manoeuvrability -10, Detection -10, Weapon Strength halved.</p>
            {{/if}}
            {{#if system.conditions.thrustersDamaged.active}}
              <p class="ship-condition-note">Thrusters Damaged: {{#if system.conditions.thrustersDamaged.turningDisabled}}The ship cannot turn.{{else}}Manoeuvrability reduced by -20.{{/if}}</p>
            {{/if}}
            {{#if system.conditions.enginesCrippled.active}}
              <p class="ship-condition-note">Engines Crippled: {{#if system.conditions.enginesCrippled.speedReducedToOne}}Speed reduced to 1.{{else}}Speed reduced by half.{{/if}}</p>
            {{/if}}
            <div class="ship-profile-grid ship-profile-grid-four">
              <div class="ship-profile-column">
                <div class="ship-profile-field">
                  <label>SPD</label>
                  <div class="ship-profile-rating-group">
                    <div class="ship-profile-rating-pair">
                      <input class="ship-profile-current {{ship.profileStats.speed.stateClass}}" type="number" value="{{ship.profileStats.speed.effective}}" step="1" readonly />
                      <span class="ship-profile-rating-separator">/</span>
                      <input name="system.speed.permanent" type="number" value="{{ship.profileStats.speed.permanent}}" step="1" />
                    </div>
                  </div>
                </div>
                <div class="ship-profile-field">
                  <label>MAN</label>
                  <div class="ship-profile-rating-group">
                    <div class="ship-profile-rating-pair">
                      <input class="ship-profile-current {{ship.profileStats.maneuverability.stateClass}}" type="number" value="{{ship.profileStats.maneuverability.effective}}" step="1" readonly />
                      <span class="ship-profile-rating-separator">/</span>
                      <input name="system.maneuverability.permanent" type="number" value="{{ship.profileStats.maneuverability.permanent}}" step="1" />
                    </div>
                  </div>
                </div>
                <div class="ship-profile-field">
                  <button type="button" class="ship-profile-roll" data-ship-test="activeAugury">DET</button>
                  <div class="ship-profile-rating-group">
                    <div class="ship-profile-rating-pair">
                      <input class="ship-profile-current {{ship.profileStats.detection.stateClass}}" type="number" value="{{ship.profileStats.detection.effective}}" step="1" readonly />
                      <span class="ship-profile-rating-separator">/</span>
                      <input name="system.detection.permanent" type="number" value="{{ship.profileStats.detection.permanent}}" step="1" />
                    </div>
                  </div>
                </div>
              </div>
              <div class="ship-profile-column">
                <div class="ship-profile-field">
                  <label>Turret Rating</label>
                  <input name="system.turretRating" type="number" value="{{system.turretRating}}" step="1" />
                </div>
                <div class="ship-profile-field">
                  <label>Shields</label>
                  <input name="system.shields" type="number" value="{{system.shields}}" step="1" />
                </div>
                <div class="ship-profile-field">
                  <label>Armour</label>
                  <input name="system.armor" type="number" value="{{system.armor}}" step="1" />
                </div>
              </div>
              <div class="ship-profile-column">
                <div class="ship-profile-field">
                  <label>Hull Integrity</label>
                  <div class="ship-profile-rating-group">
                    <div class="ship-profile-rating-pair">
                      <input class="ship-profile-current {{ship.resourceStats.hullIntegrity.stateClass}}" name="system.resources.hullIntegrity.value" type="number" value="{{ship.resourceStats.hullIntegrity.current}}" step="1" />
                      <span class="ship-profile-rating-separator">/</span>
                      <input name="system.resources.hullIntegrity.max" type="number" value="{{ship.resourceStats.hullIntegrity.permanent}}" step="1" />
                    </div>
                  </div>
                </div>
                <div class="ship-profile-field">
                  <label>Crew %</label>
                  <div class="ship-profile-rating-group">
                    <div class="ship-profile-rating-pair">
                      <input class="ship-profile-current {{ship.resourceStats.crew.stateClass}}" name="system.crew.value" type="number" value="{{ship.resourceStats.crew.current}}" step="1" />
                      <span class="ship-profile-rating-separator">/</span>
                      <input name="system.crew.max" type="number" value="{{ship.resourceStats.crew.permanent}}" step="1" />
                    </div>
                  </div>
                </div>
                <div class="ship-profile-field">
                  <label>Morale</label>
                  <div class="ship-profile-rating-group">
                    <div class="ship-profile-rating-pair">
                      <input class="ship-profile-current {{ship.resourceStats.morale.stateClass}}" name="system.resources.morale.value" type="number" value="{{ship.resourceStats.morale.current}}" step="1" />
                      <span class="ship-profile-rating-separator">/</span>
                      <input name="system.resources.morale.max" type="number" value="{{ship.resourceStats.morale.permanent}}" step="1" />
                    </div>
                  </div>
                </div>
              </div>
              <div class="ship-profile-column">
                <div class="ship-profile-field">
                  <label>Power</label>
                  <div class="ship-profile-rating-group">
                    <div class="ship-profile-rating-pair">
                      <input class="ship-profile-current {{ship.resourceStats.power.stateClass}}" type="number" value="{{ship.resourceStats.power.current}}" step="1" readonly />
                      <span class="ship-profile-rating-separator">/</span>
                      <input name="system.power.value" type="number" value="{{ship.resourceStats.power.permanent}}" step="1" />
                    </div>
                  </div>
                </div>
                <div class="ship-profile-field">
                  <label>Space</label>
                  <div class="ship-profile-rating-group">
                    <div class="ship-profile-rating-pair">
                      <input class="ship-profile-current {{ship.resourceStats.space.stateClass}}" type="number" value="{{ship.resourceStats.space.current}}" step="1" readonly />
                      <span class="ship-profile-rating-separator">/</span>
                      <input name="system.space.value" type="number" value="{{ship.resourceStats.space.permanent}}" step="1" />
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </section>

          <div class="ship-sheet-wide">
            <section class="ship-card ship-wide-table-card">
              <div class="ship-section-header">
                <h2>Ship Weapons</h2>
              </div>
              {{#if ship.hasShipWeapons}}
                <div class="ship-table-wrap">
                  <table class="ship-data-table ship-weapon-table">
                    <thead>
                      <tr>
                        <th></th>
                        <th>Name</th>
                        <th>Type</th>
                        <th>Mount</th>
                        <th>Strength</th>
                        <th>Damage</th>
                        <th>Crit</th>
                        <th>Range</th>
                        <th>SP</th>
                        <th>Power</th>
                        <th>Space</th>
                        <th>Action</th>
                      </tr>
                    </thead>
                    <tbody>
                      {{#each ship.shipWeapons as |weapon|}}
                        <tr>
                          <td class="ship-table-icon-cell"><img class="ship-table-icon" src="{{weapon.img}}" alt="{{weapon.name}}" /></td>
                          <td><button type="button" class="ship-item-open ship-list-primary" data-item-id="{{weapon.id}}">{{weapon.name}}</button></td>
                          <td>{{weapon.weaponClassLabel}}</td>
                          <td>{{weapon.locationLabel}}</td>
                          <td>{{weapon.strength}}</td>
                          <td>{{weapon.damage}}</td>
                          <td>{{weapon.critRating}}</td>
                          <td>{{weapon.range}}</td>
                          <td>{{weapon.shipPointCost}}</td>
                          <td>{{weapon.power}}</td>
                          <td>{{weapon.space}}</td>
                          <td>
                            {{#if weapon.isTorpedoTube}}
                              {{#if weapon.torpedoLoading}}
                                <div class="ship-weapon-load-status">{{weapon.torpedoLoadingModeLabel}}</div>
                              {{else}}
                                {{#if weapon.torpedoLoaded}}
                                  <button type="button" class="ship-weapon-fire" data-item-id="{{weapon.id}}" aria-label="Fire {{weapon.name}}"><i class="fas fa-crosshairs"></i></button>
                                {{else}}
                                  <div class="ship-weapon-load-controls">
                                    <select class="ship-weapon-load-mode" data-item-id="{{weapon.id}}">
                                      {{#each ../ship.torpedoLoadOptions as |option|}}
                                        <option value="{{option.value}}">{{option.label}}</option>
                                      {{/each}}
                                    </select>
                                    <button type="button" class="ship-weapon-load" data-item-id="{{weapon.id}}">Load</button>
                                  </div>
                                {{/if}}
                              {{/if}}
                            {{else}}
                                <button type="button" class="ship-weapon-fire" data-item-id="{{weapon.id}}" aria-label="Fire {{weapon.name}}"><i class="fas fa-crosshairs"></i></button>
                            {{/if}}
                          </td>
                        </tr>
                      {{/each}}
                    </tbody>
                  </table>
                </div>
              {{else}}
                <p class="ship-empty-state">Drop ship weapons here.</p>
              {{/if}}
            </section>

            <section class="ship-card ship-wide-table-card">
              <div class="ship-section-header">
                <h2>Essential Components</h2>
              </div>
              {{#if ship.hasEssentialComponents}}
                <div class="ship-table-wrap">
                  <table class="ship-data-table">
                    <thead>
                    <tr>
                      <th>Name</th>
                      <th>Type</th>
                      <th>SP</th>
                      <th>Power</th>
                      <th>Space</th>
                      <th>Summary</th>
                    </tr>
                    </thead>
                    <tbody>
                      {{#each ship.essentialComponents as |component|}}
                        <tr>
                          <td><button type="button" class="ship-item-open ship-list-primary" data-item-id="{{component.id}}">{{component.name}}</button></td>
                        <td>{{component.componentType}}</td>
                        <td>{{component.shipPointCost}}</td>
                        <td>{{component.power}}</td>
                        <td>{{component.space}}</td>
                        <td>{{component.shortDescription}}</td>
                      </tr>
                      {{/each}}
                    </tbody>
                  </table>
                </div>
              {{else}}
                <p class="ship-empty-state">Drop essential components here.</p>
              {{/if}}
            </section>

            <section class="ship-card ship-wide-table-card">
              <div class="ship-section-header">
                <h2>Supplemental Components</h2>
              </div>
              {{#if ship.hasSupplementalComponents}}
                <div class="ship-table-wrap">
                  <table class="ship-data-table">
                    <thead>
                    <tr>
                      <th>Name</th>
                      <th>Type</th>
                      <th>SP</th>
                      <th>Power</th>
                      <th>Space</th>
                      <th>Summary</th>
                    </tr>
                    </thead>
                    <tbody>
                      {{#each ship.supplementalComponents as |component|}}
                        <tr>
                          <td><button type="button" class="ship-item-open ship-list-primary" data-item-id="{{component.id}}">{{component.name}}</button></td>
                        <td>{{component.componentType}}</td>
                        <td>{{component.shipPointCost}}</td>
                        <td>{{component.power}}</td>
                        <td>{{component.space}}</td>
                        <td>{{component.shortDescription}}</td>
                      </tr>
                      {{/each}}
                    </tbody>
                  </table>
                </div>
              {{else}}
                <p class="ship-empty-state">Drop supplemental components here.</p>
              {{/if}}
            </section>

            <section class="ship-card ship-wide-table-card">
              <div class="ship-section-header">
                <h2>Voidship Effects</h2>
              </div>
              {{#if ship.hasEffects}}
                <div class="ship-table-wrap">
                  <table class="ship-data-table ship-effects-table">
                    <thead>
                      <tr>
                        <th>Source</th>
                        <th>Type</th>
                        <th>Effect</th>
                      </tr>
                    </thead>
                    <tbody>
                      {{#each ship.effects as |entry|}}
                        <tr>
                          <td>{{entry.source}}</td>
                          <td>{{entry.type}}</td>
                          <td>{{entry.effect}}</td>
                        </tr>
                      {{/each}}
                    </tbody>
                  </table>
                </div>
              {{else}}
                <p class="ship-empty-state">No active ship buffs, debuffs, or conditions.</p>
              {{/if}}
            </section>

          </div>
        </section>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="page-two">
      <div class="ship-sheet-frame">
        <section class="ship-sheet-main">
          <div class="ship-sheet-left">
            <section class="ship-card">
              <div class="ship-section-header">
                <h2>Starship Hull</h2>
              </div>
              {{#if ship.activeHull}}
                <div class="ship-hull-summary">
                  <div class="ship-hull-summary-header">
                    <button type="button" class="ship-item-open ship-list-primary" data-item-id="{{ship.activeHull.id}}">{{ship.activeHull.name}}</button>
                  </div>
                  <div class="ship-hull-stat-grid">
                    <div><strong>Dimensions:</strong> {{ship.activeHull.dimensions}}</div>
                    <div><strong>Mass:</strong> {{ship.activeHull.mass}}</div>
                    <div><strong>Crew:</strong> {{ship.activeHull.crewComplement}}</div>
                    <div><strong>Accel:</strong> {{ship.activeHull.acceleration}}</div>
                    <div><strong>Ship Points:</strong> {{ship.activeHull.shipPoints}}</div>
                    <div><strong>Space:</strong> {{ship.activeHull.space}}</div>
                    <div><strong>Weapon Capacity:</strong> {{#if ship.weaponCapacityDisplay}}{{ship.weaponCapacityDisplay}}{{else}}None{{/if}}</div>
                  </div>
                  {{#if ship.activeHull.shortDescription}}
                    <p class="ship-empty-state">{{ship.activeHull.shortDescription}}</p>
                  {{/if}}
                  {{#if ship.activeHull.specialRules}}
                    <div class="ship-hull-rules">{{ship.activeHull.specialRules}}</div>
                  {{/if}}
                </div>
              {{else}}
                <p class="ship-empty-state">No hull applied yet. Create a Starship Hull item or click Construct Voidship to choose one.</p>
              {{/if}}
            </section>

            <section class="ship-card">
              <h2>Complications / Past History</h2>
              <textarea class="ship-history-field" name="system.pastHistory">{{system.pastHistory}}</textarea>
            </section>
          </div>

          <div class="ship-sheet-right">
            <section class="ship-card">
              <h2>Traits</h2>
              <textarea class="ship-history-field ship-traits-field" name="system.traits">{{system.traits}}</textarea>
            </section>

            <section class="ship-card">
              <h2>Cargo / Other Items</h2>
              <div class="ship-component-list">
                {{#if ship.hasCargo}}
                  {{#each ship.cargo as |item|}}
                    <div class="ship-list-row">
                      <button type="button" class="ship-item-open ship-list-primary" data-item-id="{{item.id}}">{{item.name}}</button>
                      <div class="ship-list-meta">{{item.typeLabel}}</div>
                      <button type="button" class="ship-item-delete" data-item-id="{{item.id}}">X</button>
                    </div>
                  {{/each}}
                {{else}}
                  <p class="ship-empty-state">Drop cargo and miscellaneous items here.</p>
                {{/if}}
              </div>
            </section>
          </div>
        </section>
      </div>
    </div>
  </section>
</form>
