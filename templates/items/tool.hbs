<div class="tool-sheet item-sheet-layout">
  <header class="item-sheet-header">
    <img
      class="item-sheet-icon"
      src="{{item.img}}"
      data-action="editImage"
      data-edit="img"
      title="{{item.name}}"
      alt="{{item.name}}"
    />

    <div class="item-sheet-header-fields">
      <div class="form-group full-width">
        <label for="{{rootId}}-name">Name</label>
        <input id="{{rootId}}-name" name="name" type="text" value="{{item.name}}" placeholder="Tool Name" />
      </div>
    </div>
  </header>

  <section class="item-sheet-body tool-sheet-body">
    <section class="item-sheet-grid tool-grid">
      <div class="form-group">
        <label for="{{rootId}}-weight">Weight</label>
        <div class="inline-unit-field">
          <input id="{{rootId}}-weight" name="system.weight" type="number" value="{{system.weight}}" min="0" step="0.1" />
          <span>kg</span>
        </div>
      </div>

      <div class="form-group">
        <label for="{{rootId}}-availability">Availability</label>
        <select id="{{rootId}}-availability" name="system.availability">
          {{selectOptions availabilityOptions selected=system.availability}}
        </select>
      </div>

      <div class="form-group">
        <label for="{{rootId}}-craftsmanship">Craftsmanship</label>
        <select id="{{rootId}}-craftsmanship" name="system.craftsmanship">
          {{selectOptions craftsmanshipOptions selected=system.craftsmanship}}
        </select>
      </div>
    </section>

    <section class="form-group stacked tool-short-description">
      <label for="{{rootId}}-short-description">Short Description</label>
      <textarea id="{{rootId}}-short-description" name="system.shortDescription" rows="3" placeholder="Short description">{{system.shortDescription}}</textarea>
    </section>

    <section class="form-group stacked tool-description">
      <label for="{{rootId}}-description">Description</label>
      <textarea id="{{rootId}}-description" name="system.description" rows="10" placeholder="Long description">{{system.description}}</textarea>
    </section>
  </section>
</div>
