<div class="cybernetic-sheet item-sheet-layout">
  <header class="item-sheet-header">
    <img
      class="item-sheet-icon"
      src="{{item.img}}"
      data-action="editImage"
      data-edit="img"
      title="{{item.name}}"
      alt="{{item.name}}"
    />

    <div class="item-sheet-header-fields">
      <div class="form-group full-width">
        <label for="{{rootId}}-name">Name</label>
        <input id="{{rootId}}-name" name="name" type="text" value="{{item.name}}" placeholder="Cybernetic Name" />
      </div>
    </div>
  </header>

  <section class="item-sheet-body cybernetic-sheet-body">
    <section class="item-sheet-grid cybernetic-grid">
      <div class="form-group">
        <label for="{{rootId}}-weight">Weight</label>
        <div class="inline-unit-field">
          <input id="{{rootId}}-weight" name="system.weight" type="number" value="{{system.weight}}" min="0" step="0.1" />
          <span>kg</span>
        </div>
      </div>

      <div class="form-group">
        <label for="{{rootId}}-availability">Availability</label>
        <select id="{{rootId}}-availability" name="system.availability">
          {{selectOptions availabilityOptions selected=system.availability}}
        </select>
      </div>

      <div class="form-group">
        <label for="{{rootId}}-craftsmanship">Craftsmanship</label>
        <select id="{{rootId}}-craftsmanship" name="system.craftsmanship">
          {{selectOptions craftsmanshipOptions selected=system.craftsmanship}}
        </select>
      </div>
    </section>

    <section class="cybernetic-armour-section">
      <div class="form-group checkbox-row cybernetic-armour-toggle">
        <label class="checkbox-inline" for="{{rootId}}-adds-armour">
          <input id="{{rootId}}-adds-armour" name="system.addsArmour" type="checkbox" {{checked system.addsArmour}} />
          <span>Adds Armour</span>
        </label>
      </div>

      {{#if system.addsArmour}}
        <div class="item-sheet-grid cybernetic-armour-grid">
          <div class="form-group compact">
            <label for="{{rootId}}-armour-head">Head</label>
            <input id="{{rootId}}-armour-head" name="system.armourBonus.head" type="number" value="{{system.armourBonus.head}}" min="0" step="1" />
          </div>

          <div class="form-group compact">
            <label for="{{rootId}}-armour-arms">Arms</label>
            <input id="{{rootId}}-armour-arms" name="system.armourBonus.arms" type="number" value="{{system.armourBonus.arms}}" min="0" step="1" />
          </div>

          <div class="form-group compact">
            <label for="{{rootId}}-armour-body">Body</label>
            <input id="{{rootId}}-armour-body" name="system.armourBonus.body" type="number" value="{{system.armourBonus.body}}" min="0" step="1" />
          </div>

          <div class="form-group compact">
            <label for="{{rootId}}-armour-legs">Legs</label>
            <input id="{{rootId}}-armour-legs" name="system.armourBonus.legs" type="number" value="{{system.armourBonus.legs}}" min="0" step="1" />
          </div>
        </div>
      {{/if}}
    </section>

    <section class="form-group stacked cybernetic-short-description">
      <label for="{{rootId}}-short-description">Short Description</label>
      <textarea id="{{rootId}}-short-description" name="system.shortDescription" rows="3" placeholder="Short description">{{system.shortDescription}}</textarea>
    </section>

    <section class="form-group stacked cybernetic-description">
      <label for="{{rootId}}-description">Description</label>
      <textarea id="{{rootId}}-description" name="system.description" rows="10" placeholder="Long description">{{system.description}}</textarea>
    </section>
  </section>
</div>
