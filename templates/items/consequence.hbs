<div class="consequence-sheet item-sheet-layout">
  <header class="item-sheet-header">
    <img
      class="item-sheet-icon"
      src="{{item.img}}"
      data-action="editImage"
      data-edit="img"
      title="{{item.name}}"
      alt="{{item.name}}"
    />

    <div class="item-sheet-header-fields">
      <div class="form-group full-width">
        <label for="{{rootId}}-name">Name</label>
        <input
          id="{{rootId}}-name"
          name="name"
          type="text"
          value="{{item.name}}"
          placeholder="{{typeLabel}} Name"
        />
      </div>

      <p class="item-sheet-subtitle">{{typeLabel}}</p>
    </div>
  </header>

  <section class="item-sheet-body consequence-sheet-body">
    <section class="form-group stacked">
      <label for="{{rootId}}-summary">Summary</label>
      <input
        id="{{rootId}}-summary"
        name="system.summary"
        type="text"
        value="{{system.summary}}"
        placeholder="Short mechanical summary"
      />
    </section>

    <section class="item-sheet-grid item-sheet-grid-two consequence-sheet-grid">
      <div class="form-group">
        <label for="{{rootId}}-source-table">Source Table</label>
        <input
          id="{{rootId}}-source-table"
          name="system.sourceTable"
          type="text"
          value="{{system.sourceTable}}"
          placeholder="mutations"
        />
      </div>

      <div class="form-group">
        <label for="{{rootId}}-roll-range">Roll Range</label>
        <input
          id="{{rootId}}-roll-range"
          name="system.rollRange"
          type="text"
          value="{{system.rollRange}}"
          placeholder="01-05"
        />
      </div>

      {{#if showSeverity}}
        <div class="form-group">
          <label for="{{rootId}}-severity">Severity</label>
          <input
            id="{{rootId}}-severity"
            name="system.severity"
            type="text"
            value="{{system.severity}}"
            placeholder="Minor, Severe, Acute"
          />
        </div>
      {{/if}}
    </section>

    {{#if hasTraitModifiers}}
      <section class="item-sheet-grid item-sheet-grid-two consequence-sheet-grid">
        <div class="form-group">
          <label for="{{rootId}}-modifier-formula">Trait Modifier</label>
          <input
            id="{{rootId}}-modifier-formula"
            name="system.modifierFormula"
            type="text"
            value="{{system.modifierFormula}}"
            placeholder="Perception -1d10, Charm -20"
          />
        </div>

        <div class="form-group">
          <label for="{{rootId}}-resolved-modifiers">Resolved Trait Modifier</label>
          <input
            id="{{rootId}}-resolved-modifiers"
            name="system.resolvedModifiers"
            type="text"
            value="{{system.resolvedModifiers}}"
            placeholder="Perception -6, Charm -20"
          />
        </div>
      </section>
    {{/if}}

    <section class="form-group stacked">
      <label for="{{rootId}}-notes">Notes</label>
      <input
        id="{{rootId}}-notes"
        name="system.notes"
        type="text"
        value="{{system.notes}}"
        placeholder="Tags, duration, escalation, or GM notes"
      />
    </section>

    <section class="form-group stacked">
      <label for="{{rootId}}-description">Description</label>
      <textarea
        id="{{rootId}}-description"
        name="system.description"
        rows="14"
        placeholder="Full rules text"
      >{{system.description}}</textarea>
    </section>
  </section>
</div>
