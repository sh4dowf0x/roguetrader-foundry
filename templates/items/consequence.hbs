<form class="{{cssClass}} item-sheet-layout consequence-sheet" autocomplete="off">
  <header class="item-sheet-header">
    <img class="item-sheet-icon" src="{{item.img}}" data-edit="img" title="{{item.name}}" alt="{{item.name}}" />

    <div class="item-sheet-header-fields">
      <h1 class="item-sheet-name">
        <input name="name" type="text" value="{{item.name}}" placeholder="{{typeLabel}} Name" />
      </h1>

      <div class="item-sheet-subtitle">{{typeLabel}}</div>
    </div>
  </header>

  <section class="item-sheet-body">
    <div class="form-group">
      <label>Summary</label>
      <input
        name="system.summary"
        type="text"
        value="{{system.summary}}"
        placeholder="Short mechanical summary"
      />
    </div>

    <div class="item-sheet-grid item-sheet-grid-two">
      <div class="form-group">
        <label>Source Table</label>
        <input
          name="system.sourceTable"
          type="text"
          value="{{system.sourceTable}}"
          placeholder="mutations"
        />
      </div>

      <div class="form-group">
        <label>Roll Range</label>
        <input
          name="system.rollRange"
          type="text"
          value="{{system.rollRange}}"
          placeholder="01-05"
        />
      </div>
    </div>

    {{#if showSeverity}}
      <div class="form-group">
        <label>Severity</label>
        <input
          name="system.severity"
          type="text"
          value="{{system.severity}}"
          placeholder="Minor, Severe, Acute"
        />
      </div>
    {{/if}}

    {{#if hasTraitModifiers}}
      <div class="form-group">
        <label>Trait Modifier</label>
        <input
          name="system.modifierFormula"
          type="text"
          value="{{system.modifierFormula}}"
          placeholder="Perception -1d10, Charm -20"
        />
      </div>

      <div class="form-group">
        <label>Resolved Trait Modifier</label>
        <input
          name="system.resolvedModifiers"
          type="text"
          value="{{system.resolvedModifiers}}"
          placeholder="Perception -6, Charm -20"
        />
      </div>
    {{/if}}

    <div class="form-group">
      <label>Notes</label>
      <input
        name="system.notes"
        type="text"
        value="{{system.notes}}"
        placeholder="Tags, duration, escalation, or GM notes"
      />
    </div>

    <div class="form-group stacked">
      <label>Description</label>
      <textarea
        name="system.description"
        rows="14"
        placeholder="Full rules text"
      >{{system.description}}</textarea>
    </div>
  </section>
</form>

