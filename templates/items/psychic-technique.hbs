<div class="psychic-technique-sheet item-sheet-layout">
  <header class="item-sheet-header">
    <img
      class="item-sheet-icon"
      src="{{item.img}}"
      data-action="editImage"
      data-edit="img"
      title="{{item.name}}"
      alt="{{item.name}}"
    />

    <div class="item-sheet-header-fields">
      <div class="form-group full-width">
        <label for="{{rootId}}-name">Name</label>
        <input
          id="{{rootId}}-name"
          name="name"
          type="text"
          value="{{item.name}}"
          placeholder="Psychic Technique"
        />
      </div>
      <p class="item-sheet-subtitle">Warp-Tempered Power</p>
    </div>
  </header>

  <section class="item-sheet-body psychic-technique-sheet-body">
    <section class="item-sheet-grid item-sheet-grid-two psychic-technique-grid">
      <div class="form-group">
        <label for="{{rootId}}-value">Value</label>
        <select id="{{rootId}}-value" name="system.value">
          {{selectOptions valueOptions selected=system.value}}
        </select>
      </div>

      <div class="form-group">
        <label for="{{rootId}}-focus-power-test">Focus Power Test</label>
        <select id="{{rootId}}-focus-power-test" name="system.focusPowerTest">
          {{selectOptions focusPowerTestOptions selected=system.focusPowerTest}}
        </select>
      </div>

      <div class="form-group">
        <label for="{{rootId}}-focus-time">Focus Time</label>
        <select id="{{rootId}}-focus-time" name="system.focusTime">
          {{selectOptions focusTimeOptions selected=system.focusTime}}
        </select>
      </div>

      <div class="form-group">
        <label for="{{rootId}}-sustain">Sustain</label>
        <select id="{{rootId}}-sustain" name="system.sustain">
          {{selectOptions sustainOptions selected=system.sustain}}
        </select>
      </div>
    </section>

    <section class="form-group stacked">
      <label for="{{rootId}}-prerequisites">Prerequisites</label>
      <input
        id="{{rootId}}-prerequisites"
        name="system.prerequisites"
        type="text"
        value="{{system.prerequisites}}"
        placeholder="Discipline, rank, traits"
      />
    </section>

    <section class="form-group stacked">
      <label for="{{rootId}}-range">Range</label>
      <input
        id="{{rootId}}-range"
        name="system.range"
        type="text"
        value="{{system.range}}"
        placeholder="Self, 10m, Psy Rating x 5m"
      />
    </section>

    <section class="form-group stacked">
      <label for="{{rootId}}-description">Description</label>
      <textarea
        id="{{rootId}}-description"
        name="system.description"
        rows="12"
        placeholder="Details and description of the psychic technique"
      >{{system.description}}</textarea>
    </section>
  </section>
</div>
