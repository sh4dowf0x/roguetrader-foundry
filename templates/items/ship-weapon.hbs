<div class="ship-weapon-sheet item-sheet-layout">
  <header class="item-sheet-header">
    <img class="item-sheet-icon" src="{{item.img}}" data-action="editImage" data-edit="img" title="{{item.name}}" alt="{{item.name}}" />
    <div class="item-sheet-header-fields">
      <div class="form-group full-width">
        <label for="{{rootId}}-name">Name</label>
        <input id="{{rootId}}-name" name="name" type="text" value="{{item.name}}" />
      </div>
      <p class="item-sheet-subtitle">Ship Weapon</p>
    </div>
  </header>

  <section class="item-sheet-body item-body-grid">
    <div class="ship-weapon-top-row item-body-grid-span">
      <div class="form-group ship-weapon-type-field">
        <label for="{{rootId}}-weapon-class">Type</label>
        <select id="{{rootId}}-weapon-class" name="system.weaponClass">
          {{selectOptions weaponClassOptions selected=system.weaponClass}}
        </select>
      </div>

      {{#if isTorpedoWeapon}}
        <div class="form-group ship-weapon-type-field">
          <label for="{{rootId}}-torpedo-type">Torpedo Type</label>
          <select id="{{rootId}}-torpedo-type" name="system.torpedoType">
            {{selectOptions torpedoTypeOptions selected=system.torpedoType}}
          </select>
        </div>
        <div class="form-group ship-weapon-type-field">
          <label for="{{rootId}}-torpedo-guidance">Guidance</label>
          <select id="{{rootId}}-torpedo-guidance" name="system.torpedoGuidance">
            {{selectOptions torpedoGuidanceOptions selected=system.torpedoGuidance}}
          </select>
        </div>
      {{/if}}

      <div class="ship-weapon-stat-row">
        <div class="form-group ship-weapon-mini-field">
          <label for="{{rootId}}-power">Power</label>
          <input id="{{rootId}}-power" name="system.power" type="number" value="{{system.power}}" step="1" />
        </div>

        <div class="form-group ship-weapon-mini-field">
          <label for="{{rootId}}-space">Space</label>
          <input id="{{rootId}}-space" name="system.space" type="number" value="{{system.space}}" step="1" />
        </div>

        <div class="form-group ship-weapon-mini-field">
          <label for="{{rootId}}-sp-cost">SP Cost</label>
          <input id="{{rootId}}-sp-cost" name="system.shipPointCost" type="number" value="{{system.shipPointCost}}" step="1" />
        </div>
      </div>
    </div>

    <div class="ship-weapon-stat-row item-body-grid-span">
      {{#if isTorpedoWeapon}}
        <div class="form-group ship-weapon-mini-field">
          <label for="{{rootId}}-torpedo-speed">Speed</label>
          <input id="{{rootId}}-torpedo-speed" name="system.torpedoSpeed" type="number" value="{{system.torpedoSpeed}}" step="1" readonly />
        </div>
      {{/if}}

      <div class="form-group ship-weapon-mini-field">
        <label for="{{rootId}}-strength">Strength</label>
        <input id="{{rootId}}-strength" name="system.strength" type="text" value="{{system.strength}}" />
      </div>

      <div class="form-group ship-weapon-wide-field">
        <label for="{{rootId}}-damage">Damage</label>
        <input id="{{rootId}}-damage" name="system.damage" type="text" value="{{system.damage}}" {{#if isTorpedoWeapon}}readonly{{/if}} />
      </div>

      <div class="form-group ship-weapon-mini-field">
        <label for="{{rootId}}-crit-rating">Crit Rating</label>
        <input id="{{rootId}}-crit-rating" name="system.critRating" type="text" value="{{system.critRating}}" {{#if isTorpedoWeapon}}readonly{{/if}} />
      </div>

      <div class="form-group ship-weapon-wide-field">
        <label for="{{rootId}}-range">Range</label>
        <input id="{{rootId}}-range" name="system.range" type="text" value="{{system.range}}" {{#if isTorpedoWeapon}}readonly{{/if}} />
      </div>
    </div>

    <div class="form-group item-body-grid-span">
      <label>Allowed Hulls</label>
      <div class="ship-component-hull-flags">
        {{#each hullAvailabilityOptions as |option|}}
          <label class="ship-component-hull-flag" for="{{../rootId}}-hull-{{option.key}}">
            <input id="{{../rootId}}-hull-{{option.key}}" type="checkbox" name="system.allowedHulls.{{option.key}}" {{checked (lookup ../system.allowedHulls option.key)}} />
            <span>{{option.label}}</span>
          </label>
        {{/each}}
      </div>
    </div>

    <div class="form-group item-body-grid-span">
      <label>Mount Locations</label>
      <div class="ship-component-hull-flags">
        {{#each mountLocationOptions as |option|}}
          <label class="ship-component-hull-flag" for="{{../rootId}}-mount-{{option.key}}">
            <input id="{{../rootId}}-mount-{{option.key}}" type="checkbox" name="system.allowedLocations.{{option.key}}" {{checked (lookup ../system.allowedLocations option.key)}} />
            <span>{{option.label}}</span>
          </label>
        {{/each}}
      </div>
    </div>

    <div class="form-group item-body-grid-span">
      <label for="{{rootId}}-short-description">Short Description</label>
      <input id="{{rootId}}-short-description" name="system.shortDescription" type="text" value="{{system.shortDescription}}" />
    </div>

    <div class="form-group item-body-grid-span">
      <label for="{{rootId}}-description">Description</label>
      <textarea id="{{rootId}}-description" name="system.description">{{system.description}}</textarea>
    </div>
  </section>
</div>
