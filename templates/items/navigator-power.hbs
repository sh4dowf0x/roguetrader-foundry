<div class="navigator-power-sheet item-sheet-layout">
  <header class="item-sheet-header">
    <img
      class="item-sheet-icon"
      src="{{item.img}}"
      data-action="editImage"
      data-edit="img"
      title="{{item.name}}"
      alt="{{item.name}}"
    />

    <div class="item-sheet-header-fields">
      <div class="form-group full-width">
        <label for="{{rootId}}-name">Name</label>
        <input
          id="{{rootId}}-name"
          name="name"
          type="text"
          value="{{item.name}}"
          placeholder="Navigator Power"
        />
      </div>
      <p class="item-sheet-subtitle">Warp-Eye Technique</p>
    </div>
  </header>

  <section class="item-sheet-body navigator-power-sheet-body">
    <section class="item-sheet-grid item-sheet-grid-two navigator-power-grid">
      <div class="form-group">
        <label for="{{rootId}}-mastery">Mastery</label>
        <select id="{{rootId}}-mastery" name="system.mastery">
          {{selectOptions masteryOptions selected=system.mastery}}
        </select>
      </div>
    </section>

    <section class="form-group stacked">
      <label for="{{rootId}}-benefit">Benefit</label>
      <textarea
        id="{{rootId}}-benefit"
        name="system.benefit"
        rows="3"
        placeholder="Short summary of the navigator power"
      >{{system.benefit}}</textarea>
    </section>

    <section class="form-group stacked">
      <label for="{{rootId}}-description">Description</label>
      <textarea
        id="{{rootId}}-description"
        name="system.description"
        rows="12"
        placeholder="Full rules text and narrative details"
      >{{system.description}}</textarea>
    </section>
  </section>
</div>
