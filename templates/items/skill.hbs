<div class="skill-sheet item-sheet-layout">
  <header class="item-sheet-header">
    <img
      class="item-sheet-icon"
      src="{{item.img}}"
      data-action="editImage"
      data-edit="img"
      title="{{item.name}}"
      alt="{{item.name}}"
    />

    <div class="item-sheet-header-fields">
      <div class="form-group full-width">
        <label for="{{rootId}}-name">Name</label>
        <input
          id="{{rootId}}-name"
          name="name"
          type="text"
          value="{{item.name}}"
          placeholder="Skill Name"
        />
      </div>
      <p class="item-sheet-subtitle">Learned Skill</p>
    </div>
  </header>

  <section class="item-sheet-body skill-sheet-body">
    <section class="item-sheet-grid item-sheet-grid-two skill-sheet-grid">
      <div class="form-group">
        <label for="{{rootId}}-characteristic">Characteristic</label>
        <select id="{{rootId}}-characteristic" name="system.characteristic">
          {{selectOptions characteristics selected=system.characteristic}}
        </select>
      </div>

      <div class="form-group">
        <label for="{{rootId}}-bonus">Bonus</label>
        <input
          id="{{rootId}}-bonus"
          name="system.bonus"
          type="number"
          value="{{system.bonus}}"
          step="1"
        />
      </div>
    </section>

    <section class="form-group">
      <label for="{{rootId}}-specialization">Specialization</label>
      <input
        id="{{rootId}}-specialization"
        name="system.specialization"
        type="text"
        value="{{system.specialization}}"
        placeholder="Xenos"
      />
    </section>

    <section class="form-group stacked">
      <label>Training</label>
      <div class="skill-sheet-checkbox-grid">
        <label class="skill-sheet-checkbox">
          <input
            name="system.basic"
            type="checkbox"
            {{checked system.basic}}
          />
          <span>Basic</span>
        </label>
        <label class="skill-sheet-checkbox">
          <input
            name="system.trained"
            type="checkbox"
            {{checked system.trained}}
          />
          <span>Trained</span>
        </label>
        <label class="skill-sheet-checkbox">
          <input
            name="system.advance10"
            type="checkbox"
            {{checked system.advance10}}
          />
          <span>+10</span>
        </label>
        <label class="skill-sheet-checkbox">
          <input
            name="system.advance20"
            type="checkbox"
            {{checked system.advance20}}
          />
          <span>+20</span>
        </label>
      </div>
    </section>

    <section class="form-group stacked">
      <label for="{{rootId}}-description">Description</label>
      <textarea
        id="{{rootId}}-description"
        name="system.description"
        rows="12"
        placeholder="Describe what this skill covers, limitations, and special use cases."
      >{{system.description}}</textarea>
    </section>
  </section>
</div>
