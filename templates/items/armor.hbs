<div class="armor-sheet item-sheet-layout">
  <header class="item-sheet-header">
    <img
      class="item-sheet-icon"
      src="{{item.img}}"
      data-action="editImage"
      data-edit="img"
      title="{{item.name}}"
      alt="{{item.name}}"
    />

    <div class="item-sheet-header-fields">
      <div class="form-group full-width">
        <label for="{{rootId}}-name">Name</label>
        <input
          id="{{rootId}}-name"
          name="name"
          type="text"
          value="{{item.name}}"
          placeholder="Armor Name"
        />
      </div>
    </div>
  </header>

  <section class="item-sheet-body armor-sheet-body">
    <section class="item-sheet-grid armor-grid">
      <div class="form-group">
        <label for="{{rootId}}-armor-type">Type</label>
        <select id="{{rootId}}-armor-type" name="system.armorType">
          {{selectOptions armorTypeOptions selected=system.armorType}}
        </select>
      </div>

      <div class="form-group">
        <label for="{{rootId}}-weight">Weight</label>
        <div class="inline-unit-field">
          <input id="{{rootId}}-weight" name="system.weight" type="number" value="{{system.weight}}" min="0" step="0.1" />
          <span>kg</span>
        </div>
      </div>

      <div class="form-group">
        <label for="{{rootId}}-availability">Availability</label>
        <select id="{{rootId}}-availability" name="system.availability">
          {{selectOptions availabilityOptions selected=system.availability}}
        </select>
      </div>

      <div class="form-group">
        <label for="{{rootId}}-craftsmanship">Craftsmanship</label>
        <select id="{{rootId}}-craftsmanship" name="system.craftsmanship">
          {{selectOptions craftsmanshipOptions selected=system.craftsmanship}}
        </select>
      </div>
    </section>

    <section class="armor-locations-section">
      <h2 class="section-title">Locations Covered</h2>

      <div class="armor-location-grid">
        {{#each locationRows as |location|}}
          <div class="armor-location-row">
            <label class="quality-checkbox armor-location-check" for="{{../rootId}}-location-{{location.key}}">
              <input id="{{../rootId}}-location-{{location.key}}" name="system.locations.{{location.key}}" type="checkbox" {{checked location.covered}} />
              <span>{{location.label}}</span>
            </label>

            <div class="form-group armor-ap-field">
              <label for="{{../rootId}}-ap-{{location.key}}">AP</label>
              <input id="{{../rootId}}-ap-{{location.key}}" name="system.ap.{{location.key}}" type="number" value="{{location.ap}}" min="0" step="1" />
            </div>
          </div>
        {{/each}}
      </div>
    </section>

    <section class="armor-specials-section">
      <h2 class="section-title">Special</h2>

      <div class="armor-specials-grid">
        {{#each armorSpecials as |quality|}}
          <label class="quality-checkbox" for="{{../rootId}}-special-{{quality.key}}">
            <input
              id="{{../rootId}}-special-{{quality.key}}"
              name="system.special.{{quality.key}}"
              type="checkbox"
              {{checked quality.checked}}
            />
            <span>{{quality.label}}</span>
          </label>
        {{/each}}
      </div>
    </section>

    <section class="form-group stacked armor-modifier-field">
      <label for="{{rootId}}-characteristic-modifiers">Characteristic Modifiers</label>
      <textarea id="{{rootId}}-characteristic-modifiers" name="system.characteristicModifiers" rows="2" placeholder="Strength +10">{{system.characteristicModifiers}}</textarea>
    </section>

    <section class="form-group stacked armor-description">
      <label for="{{rootId}}-description">Description</label>
      <textarea id="{{rootId}}-description" name="system.description" rows="10" placeholder="Armor details and notes">{{system.description}}</textarea>
    </section>
  </section>
</div>
